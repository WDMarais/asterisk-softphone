# Copy to .env (gitignored) and set for your deployment.
# The PBX domain: SIP realm for the AOR (sip:6003@<domain>) and the dev-proxy
# target host. No default in source — the app fails loud if this is unset
# (unless VITE_PBX_MOCK=1, below).
VITE_PBX_DOMAIN=your-pbx.example.com

# PBX-free dev mode. When set to 1, the app swaps in a mock RegistrationClient
# (no SIP, no socket), skips the dev proxy, and needs no VITE_PBX_DOMAIN — so the
# registration UI + FSM are drivable with no live PBX. Password "fail" simulates
# a rejected registration; any other password registers. Leave unset for real use.
# VITE_PBX_MOCK=1
